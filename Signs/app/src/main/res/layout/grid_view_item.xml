<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="UnusedIds">

    <data>

        <variable
            name="photo"
            type="com.toremetal.signs.network.SignsPhoto" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/signs_image"
            android:layout_width="@dimen/gridview_image_size"
            android:layout_height="@dimen/gridview_image_size"
            android:layout_gravity="center"
            android:adjustViewBounds="true"
            android:background="#3949AB"
            android:contentDescription="@{photo.imgVal}"
            android:fitsSystemWindows="true"
            android:padding="4dp"
            android:scaleType="fitXY"

            app:imageUrl="@{photo.imgSrcUrl}"
            tools:src="@tools:sample/backgrounds/scenic" />
<!--android:src="@{photo.imgSrcUrl}"
            app:srcCompat="@{photo.imgSrcUrl}"-->
        <TextView
            android:id="@+id/signs_imageVal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@{photo.imgVal}"
            tools:text="ImageVal" />

    </LinearLayout>

</layout><!--app:imageUrl="@{viewModel.photos.imgSrcUrl}"-->