<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:id="@+id/snackBar"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:fillViewport="true"
        android:scrollbarStyle="outsideOverlay"
        app:layout_constraintTop_toTopOf="parent"
        tools:context=".MainActivity"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextClock
                android:id="@+id/textClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@android:drawable/button_onoff_indicator_on"
                android:fontFamily="casual"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:shadowColor="#CCCCCC"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="1"
                app:layout_constraintBottom_toBottomOf="@+id/refScreen"
                app:layout_constraintEnd_toStartOf="@+id/floatingActionButton"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/refScreen"
                app:layout_constraintTop_toTopOf="@+id/refScreen"
                tools:text="1:10 PM" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/saveTheTax"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:clickable="true"
                android:contentDescription="@string/saveTaxRate"
                android:focusable="true"
                android:theme="@style/ThemeOverlay.Material3.FloatingActionButton.Secondary"
                app:backgroundTint="@color/fabSaveBackground"
                app:fabCustomSize="64dp"
                app:layout_constraintBottom_toBottomOf="@+id/textInputLayout3"
                app:layout_constraintEnd_toStartOf="@+id/textInputLayout3"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/textInputLayout3"
                app:maxImageSize="64dp"
                app:srcCompat="@drawable/ic_save" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="24dp"
                android:background="@android:drawable/btn_default"
                android:hint="@string/taxRate"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/saveTheTax"
                app:layout_constraintTop_toBottomOf="@+id/adView">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextTaxRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:minWidth="124dp"
                    android:selectAllOnFocus="true"
                    android:shadowColor="@color/black_overlay"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="1"
                    android:textColor="#FF2B2B"
                    android:textSize="28sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/subTotal"
                style="@style/Widget.PurchaseTracker.TextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@android:drawable/btn_default"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:text="@string/subtotal"
                android:textSize="24sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textInputLayout3" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tax"
                style="@style/Widget.PurchaseTracker.TextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:drawable/btn_default"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:text="@string/tax"
                android:textSize="24sp"
                app:layout_constraintEnd_toStartOf="@+id/total"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/subTotal" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/total"
                style="@style/Widget.PurchaseTracker.TextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:drawable/btn_default"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:text="@string/total"
                android:textSize="24sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/tax"
                app:layout_constraintTop_toBottomOf="@+id/subTotal" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/refScreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:contentDescription="@string/resetToZero"
                android:focusable="true"
                app:backgroundTint="@color/fab_background"
                app:fabCustomSize="64dp"
                app:layout_constraintEnd_toStartOf="@+id/textClock"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tax"
                app:maxImageSize="64dp"
                app:srcCompat="@drawable/ic_clear" />
            <!-- app:layout_constraintTop_toBottomOf="@+id/total" -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/floatingActionButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:contentDescription="@string/addToSale"
                android:focusable="true"
                app:backgroundTint="@color/fab_background"
                app:fabCustomSize="64dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/textClock"
                app:layout_constraintTop_toBottomOf="@+id/total"
                app:maxImageSize="56dp"
                app:srcCompat="@drawable/ic_add_shopping_cart" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:background="@android:drawable/btn_default"
                android:hint="@string/qty"
                android:minWidth="112dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                app:layout_constraintEnd_toStartOf="@+id/imageView"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="@+id/list"
                app:layout_constraintTop_toBottomOf="@+id/refScreen">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/quantity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="auto"
                    android:focusableInTouchMode="true"
                    android:inputType="numberSigned"
                    android:nextFocusDown="@+id/price"
                    android:nextFocusForward="@+id/price"
                    android:selectAllOnFocus="true"
                    android:shadowColor="@color/black_overlay"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="1"
                    android:textAlignment="center"
                    android:textColor="@color/fabSaveBackground"
                    android:textSize="32sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:importantForAccessibility="no"
                android:minWidth="32dp"
                android:minHeight="32dp"
                app:layout_constraintBottom_toBottomOf="@+id/textInputLayout"
                app:layout_constraintEnd_toStartOf="@+id/textInputLayout2"
                app:layout_constraintStart_toEndOf="@+id/textInputLayout"
                app:layout_constraintTop_toTopOf="@+id/textInputLayout"
                app:srcCompat="@drawable/ic_end_sale" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@android:drawable/btn_default"
                android:hint="@string/price"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                app:layout_constraintBottom_toBottomOf="@+id/textInputLayout"
                app:layout_constraintEnd_toEndOf="@+id/list"
                app:layout_constraintStart_toEndOf="@+id/imageView"
                app:layout_constraintTop_toTopOf="@+id/textInputLayout">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="auto"
                    android:focusableInTouchMode="true"
                    android:inputType="numberDecimal"
                    android:selectAllOnFocus="true"
                    android:shadowColor="@color/black_overlay"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="1"
                    android:textAlignment="center"
                    android:textColor="@color/fabSaveBackground"
                    android:textSize="32sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@android:drawable/btn_default"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:shadowColor="@color/blue"
                android:shadowDx="3"
                android:shadowDy="3"
                android:shadowRadius="1"
                android:textAlignment="center"
                android:textColor="#BC5100"
                android:textSize="24sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textInputLayout"
                tools:text="Item(1) 1 @ 2.99 " />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/service_question"
                style="@style/Widget.PurchaseTracker.TextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@android:drawable/btn_default"
                android:drawablePadding="4dp"
                android:fadingEdge="horizontal"
                android:fadingEdgeLength="1dp"
                android:padding="8dp"
                android:shadowColor="@color/red_dark"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="1"
                android:text="@string/how_was_the_service"
                android:textSize="20sp"
                app:drawableStartCompat="@drawable/ic_end_sale"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/list" />

            <LinearLayout
                android:id="@+id/options_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:drawable/btn_default"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/service_question">

                <RadioGroup
                    android:id="@+id/tip_options"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ic_store"
                    android:checkedButton="@id/option_twenty_percent"
                    android:orientation="vertical"
                    android:paddingLeft="4dp"
                    android:paddingTop="10dp"
                    android:paddingRight="4dp"
                    android:paddingBottom="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/service_question">

                    <RadioButton
                        android:id="@+id/option_twenty_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:shadowColor="@color/grey2"
                        android:shadowDx="2"
                        android:shadowDy="3"
                        android:shadowRadius="3"
                        android:text="@string/amazing_service"
                        android:textAllCaps="false"
                        android:textColor="@color/blue"
                        android:textSize="24sp" />

                    <RadioButton
                        android:id="@+id/option_eighteen_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:shadowColor="@color/grey2"
                        android:shadowDx="2"
                        android:shadowDy="3"
                        android:shadowRadius="2"
                        android:text="@string/good_service"

                        android:textColor="@color/blue"
                        android:textSize="24sp" />

                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:shadowColor="@color/grey2"
                        android:shadowDx="2"
                        android:shadowDy="3"
                        android:shadowRadius="2"
                        android:text="@string/ok_service"

                        android:textColor="@color/blue"
                        android:textSize="24sp" />

                </RadioGroup>
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/round_up_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@android:drawable/btn_default"
                android:drawablePadding="8dp"
                android:shadowColor="@color/red_dark"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="1"
                android:text="@string/round_up_tip"
                android:textAlignment="center"
                android:textColor="@color/blue"
                android:visibility="gone"
                app:drawableStartCompat="@drawable/ic_round_up"
                app:layout_constraintEnd_toEndOf="@+id/calculate_button"
                app:layout_constraintStart_toStartOf="@+id/calculate_button"
                app:layout_constraintTop_toBottomOf="@id/options_layout" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/calculate_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@android:drawable/toast_frame"
                android:contentDescription="@string/calculate"
                android:drawableEnd="@drawable/ic_end_sale"
                android:fadingEdgeLength="1dp"
                android:insetBottom="0dp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:shadowColor="@color/grey2"
                android:shadowDx="3"
                android:shadowDy="3"
                android:shadowRadius="1"
                android:text="@string/calculate"
                android:textSize="34sp"
                android:visibility="gone"
                app:backgroundTint="?android:attr/textColorHintInverse"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/round_up_switch"
                app:strokeColor="#005DFF" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tip_result"
                style="@style/Widget.PurchaseTracker.TextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:background="@color/text_background"
                android:padding="8dp"
                android:shadowColor="@color/grey2"
                android:shadowDx="3"
                android:shadowDy="3"
                android:shadowRadius="1"
                android:textColor="#D32F2F"
                android:textSize="24sp"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@+id/version"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/calculate_button"
                app:layout_constraintVertical_bias="1.0"
                tools:text="Tip Amount: $10" />
            <!--

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/feedback"
                        style="@style/Widget.PurchaseTracker.TextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:shadowColor="@color/grey"
                        android:shadowDx="2"
                        android:shadowDy="2"
                        android:shadowRadius="1"
                        android:text="@string/feedback"
                        android:textColor="@color/red_dark"
                        android:textSize="24sp"
                        app:layout_constraintBottom_toTopOf="@+id/copyright"
                        app:layout_constraintEnd_toStartOf="@+id/appStore"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tip_result"
                        app:layout_constraintVertical_bias="1.0" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/appStore"
                        style="@style/Widget.PurchaseTracker.TextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:shadowColor="@color/grey"
                        android:shadowDx="2"
                        android:shadowDy="2"
                        android:shadowRadius="1"
                        android:text="@string/app_store"
                        android:textColor="@color/red_dark"
                        android:textSize="24sp"
                        app:layout_constraintBottom_toTopOf="@+id/copyright"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintStart_toEndOf="@+id/feedback"
                        app:layout_constraintTop_toBottomOf="@+id/tip_result"
                        app:layout_constraintVertical_bias="1.0" />
            -->

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/version"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@color/text_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:shadowColor="@color/black_overlay"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="1"
                app:layout_constraintBottom_toTopOf="@+id/copyright"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tip_result"
                tools:text="Version: 22.8.32.15" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/copyright"
                style="@style/Widget.PurchaseTracker.TextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="0dp"
                android:clickable="true"
                android:focusable="true"
                android:shadowColor="@color/black_overlay"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="1"
                android:textColor="@color/red_dark"
                android:textSize="24sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="©2022™T©ReMeTaL" />

            <com.google.android.gms.ads.AdView
                android:id="@+id/adView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                ads:adSize="BANNER"
                ads:adUnitId="@string/admob_ad_id"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/adView2" />

            <LinearLayout
                android:id="@+id/adView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/ad_tm"
                android:clickable="true"
                android:contentDescription="@string/ad"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:orientation="horizontal"
                app:layout_constraintBottom_toTopOf="@+id/adView"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/toolbar1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@color/colorOnPrimary"
                android:gravity="center"
                android:translationZ="40dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="visible">

                <androidx.appcompat.widget.Toolbar
                    android:layout_width="348dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_margin="20dp"
                    android:background="?attr/colorPrimary"
                    android:foregroundGravity="center"
                    android:gravity="center"
                    android:minHeight="?attr/actionBarSize"
                    android:padding="8dp"
                    android:translationZ="30dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.18">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@color/transparent"
                        android:foregroundGravity="center"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textViewAgeConsent"
                            style="@style/Widget.PurchaseTracker.TextView"
                            android:layout_width="320dp"
                            android:layout_height="wrap_content"
                            android:background="@color/transparent"
                            android:text="@string/select_age_appropriate_nad_content_rating"
                            android:textColor="@color/fab_background"
                            android:textSize="24sp"
                            app:layout_constraintBottom_toTopOf="@+id/toolbar1"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center|center_horizontal|center_vertical"
                            android:background="@color/transparent"
                            android:orientation="horizontal"
                            android:padding="8dp">

                            <ImageButton
                                android:id="@+id/rated_g"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:layout_gravity="center"
                                android:layout_margin="4dp"
                                android:layout_weight="1"
                                android:background="@color/transparent"
                                android:contentDescription="@string/rating_g"
                                android:hapticFeedbackEnabled="true"
                                android:padding="6dp"
                                android:scaleType="fitXY"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@+id/rated_pg"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:srcCompat="@drawable/rated_g" />

                            <ImageButton
                                android:id="@+id/rated_pg"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:layout_gravity="center"
                                android:layout_margin="6dp"
                                android:layout_weight="1"
                                android:background="@color/transparent"
                                android:contentDescription="@string/rating_pg"
                                android:padding="6dp"
                                android:scaleType="fitXY"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@+id/rated_t"
                                app:layout_constraintStart_toEndOf="@+id/rated_g"
                                app:layout_constraintTop_toTopOf="parent"
                                app:srcCompat="@drawable/rated_pg" />

                            <ImageButton
                                android:id="@+id/rated_t"
                                android:layout_width="70dp"
                                android:layout_height="78dp"
                                android:layout_gravity="center"
                                android:layout_margin="6dp"
                                android:layout_weight="1"
                                android:background="@color/transparent"
                                android:contentDescription="@string/rating_t"
                                android:padding="6dp"
                                android:scaleType="fitXY"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@+id/rated_ma"
                                app:layout_constraintStart_toEndOf="@+id/rated_pg"
                                app:layout_constraintTop_toTopOf="parent"
                                app:srcCompat="@drawable/rated_t" />

                            <ImageButton
                                android:id="@+id/rated_ma"
                                android:layout_width="70dp"
                                android:layout_height="78dp"
                                android:layout_gravity="center"
                                android:layout_margin="6dp"
                                android:layout_weight="1"
                                android:background="@color/transparent"
                                android:contentDescription="@string/rating_ma"
                                android:padding="6dp"
                                android:scaleType="fitXY"
                                app:srcCompat="@drawable/rated_m" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/rated_none"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableEnd="@android:drawable/ic_delete"
                            android:text="@string/str_skip" />
                    </LinearLayout>
                </androidx.appcompat.widget.Toolbar>
            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>