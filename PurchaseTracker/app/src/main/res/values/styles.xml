<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Widget.PurchaseTracker.TextView" parent="Widget.MaterialComponents.TextView">
        <item name="android:minHeight">@dimen/min_text_height</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/im_fell_english_sc</item>
        <item name="android:textAppearance">?attr/textAppearanceBody1</item>
        <item name="android:background">@color/text_background</item>
        <item name="android:layout_gravity">center</item>
    </style>

    <style name="Widget.PurchaseTracker.CompoundButton.Switch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="android:minHeight">@dimen/min_text_height</item>
        <item name="android:fontFamily">@font/im_fell_english_sc</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textAppearance">?attr/textAppearanceBody1</item>
    </style>

    <style name="Widget.PurchaseTracker.CompoundButton.RadioButton" parent="Widget.MaterialComponents.CompoundButton.RadioButton">
        <item name="android:paddingStart">8dp</item>
        <item name="android:fontFamily">@font/im_fell_english_sc</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textAppearance">?attr/textAppearanceBody1</item>
    </style>

    <style name="Widget.PurchaseTracker.Snackbar" parent="Widget.MaterialComponents.Snackbar">
        <item name="materialThemeOverlay">@style/ThemeOverlay.PurchaseTracker.Snackbar</item>
        <item name="actionTextColorAlpha">1</item>
    </style>

    <style name="Widget.PurchaseTracker.SnackbarButton" parent="Widget.MaterialComponents.Button.TextButton.Snackbar">
        <item name="android:textColor">@color/fab_background</item>
    </style>

    <style name="ThemeOverlay.PurchaseTracker.Snackbar" parent="">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnSurface">@color/colorSecondaryVariant</item>
        <item name="android:textColor">@color/ic_launcher_background</item>

    </style>

    <style name="Widget.Theme.PurchaseTracker.ActionBar.Fullscreen" parent="Widget.AppCompat.ActionBar">
        <item name="android:background">@color/black_overlay</item>
        <item name="android:padding">0dp</item>
        <item name="android:titleMargin" tools:targetApi="n">0dp</item>
        <item name="android:height">0dp</item>
        <item name="android:width">0dp</item>
    </style>
</resources>