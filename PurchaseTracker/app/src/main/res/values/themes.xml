<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.PurchaseTracker" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <!-- Text input fields -->
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox
        </item>
        <!-- Radio buttons -->
        <item name="radioButtonStyle">@style/Widget.PurchaseTracker.CompoundButton.RadioButton
        </item>
        <!-- Switches -->
        <item name="switchStyle">@style/Widget.PurchaseTracker.CompoundButton.Switch</item>
        <item name="android:background">@color/background</item>
        <item name="android:windowBackground">@drawable/sc_background</item>

        <!-- <item name="android:actionBarItemBackground">@drawable/ic_logo</item>
       -->

        <item name="snackbarStyle">@style/Widget.PurchaseTracker.Snackbar</item>
        <item name="snackbarButtonStyle">@style/Widget.PurchaseTracker.SnackbarButton</item>
        <!--<item name="alertDialogCenterButtons">@style/Widget.PurchaseTracker.ButtonBar.AlertDialog</item>
        <item name="alertDialogTheme">@style/Widget.PurchaseTracker.ButtonBar.AlertDialog</item>
        <item name="alertDialogButtonGroupStyle">@style/Widget.PurchaseTracker.ButtonBar.AlertDialog</item>-->
        <item name="android:fontFamily">@font/im_fell_english_sc</item>
    </style>

    <style name="Theme.PurchaseTracker.Fullscreen" parent="Theme.PurchaseTracker">
        <item name="android:actionBarStyle">
            @style/Widget.Theme.PurchaseTracker.ActionBar.Fullscreen
        </item>
        <item name="android:windowActionBarOverlay">false</item>
        <item name="android:windowBackground">@null</item>
    </style>
</resources>

    <!--@android:style/Theme.DeviceDefault.NoActionBar.Fullscreen-->